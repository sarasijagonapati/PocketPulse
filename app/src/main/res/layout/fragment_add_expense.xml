<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvAddTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Expense"
            android:textColor="#0F172A"
            android:textSize="24sp"
            android:textStyle="bold"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manual cash transaction"
            android:textColor="#64748B"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#DBEAFE"
            app:strokeWidth="1dp"
            android:backgroundTint="#EFF6FF"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="💡 UPI payments are auto-detected from SMS. Use this for cash entries."
                android:textColor="#1E40AF"
                android:textSize="13sp"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="18dp">

                    <Button
                        android:id="@+id/btnTypeDebit"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="📉 Expense"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="#0F172A"
                        app:cornerRadius="8dp"
                        android:layout_marginEnd="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                    <Button
                        android:id="@+id/btnTypeCredit"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="📈 Income"
                        android:textSize="12sp"
                        android:textColor="#475569"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#CBD5E1"
                        app:cornerRadius="8dp"
                        android:layout_marginStart="4dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Amount *"
                    android:textColor="#0F172A"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
                <EditText
                    android:id="@+id/etAddAmount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@android:drawable/editbox_dropdown_light_frame"
                    android:backgroundTint="#F1F5F9"
                    android:hint="₹ 0"
                    android:paddingHorizontal="14dp"
                    android:inputType="numberDecimal"
                    android:textColor="#0F172A"
                    android:textSize="15sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:weightSum="4"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp">
                    <Button android:id="@+id/btnChip50" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="₹50" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#475569" app:strokeColor="#CBD5E1" android:textSize="11sp" android:padding="0dp" android:layout_marginEnd="4dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                    <Button android:id="@+id/btnChip100" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="₹100" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#475569" app:strokeColor="#CBD5E1" android:textSize="11sp" android:padding="0dp" android:layout_marginHorizontal="2dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                    <Button android:id="@+id/btnChip200" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="₹200" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#475569" app:strokeColor="#CBD5E1" android:textSize="11sp" android:padding="0dp" android:layout_marginHorizontal="2dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                    <Button android:id="@+id/btnChip500" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="₹500" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:textColor="#475569" app:strokeColor="#CBD5E1" android:textSize="11sp" android:padding="0dp" android:layout_marginStart="4dp" android:insetTop="0dp" android:insetBottom="0dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvMerchantLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Merchant / Place *"
                    android:textColor="#0F172A"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
                <EditText
                    android:id="@+id/etAddMerchant"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:background="@android:drawable/editbox_dropdown_light_frame"
                    android:backgroundTint="#F1F5F9"
                    android:hint="e.g., College Canteen"
                    android:paddingHorizontal="14dp"
                    android:inputType="textCapWords"
                    android:textColor="#0F172A"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/llCategorySection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textColor="#0F172A"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="65dp"
                        android:orientation="horizontal"
                        android:weightSum="5"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardFood"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginEnd="3dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#EA580C"
                            app:strokeWidth="2dp"
                            android:backgroundTint="#FFEDD5">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_gravity="center" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍟" android:textSize="16sp"/>
                                <TextView android:id="@+id/txtFood" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Food" android:textColor="#EA580C" android:textSize="11sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardTravel"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#CBD5E1"
                            app:strokeWidth="1dp"
                            android:backgroundTint="#FFFFFF">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_gravity="center" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🚙" android:textSize="16sp"/>
                                <TextView android:id="@+id/txtTravel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Travel" android:textColor="#475569" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardShopping"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#CBD5E1"
                            app:strokeWidth="1dp"
                            android:backgroundTint="#FFFFFF">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_gravity="center" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🛍️" android:textSize="16sp"/>
                                <TextView android:id="@+id/txtShopping" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shopping" android:textColor="#475569" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardUtilities"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#CBD5E1"
                            app:strokeWidth="1dp"
                            android:backgroundTint="#FFFFFF">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_gravity="center" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡" android:textSize="16sp"/>
                                <TextView android:id="@+id/txtUtilities" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Utilities" android:textColor="#475569" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardOthers"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:layout_marginStart="3dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="0dp"
                            app:strokeColor="#CBD5E1"
                            app:strokeWidth="1dp"
                            android:backgroundTint="#FFFFFF">
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:layout_gravity="center" android:gravity="center">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💬" android:textSize="16sp"/>
                                <TextView android:id="@+id/txtOthers" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Others" android:textColor="#475569" android:textSize="11sp"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Note (optional)"
                    android:textColor="#0F172A"
                    android:textStyle="bold"
                    android:textSize="14sp"/>
                <EditText
                    android:id="@+id/etAddNote"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="20dp"
                    android:background="@android:drawable/editbox_dropdown_light_frame"
                    android:backgroundTint="#F1F5F9"
                    android:hint="Add a note..."
                    android:gravity="top|start"
                    android:padding="12dp"
                    android:inputType="textShortMessage"
                    android:textColor="#0F172A"
                    android:textSize="14sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveExpense"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Add Expense"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    app:backgroundTint="#0F172A"
                    app:cornerRadius="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/llCommonExpensesWrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Common Expenses"
                android:textColor="#334155"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemQuickCanteen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                android:backgroundTint="#FFFFFF"
                android:clickable="true"
                android:focusable="true">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="14dp">
                    <TextView android:id="@+id/txt1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="College Canteen" android:textColor="#0F172A" android:textStyle="bold" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/txt1" android:text="Food" android:textColor="#64748B" android:textSize="12sp" android:layout_marginTop="2dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="₹150" android:textColor="#0F172A" android:textStyle="bold" android:textSize="14sp"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemQuickMetro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                android:backgroundTint="#FFFFFF"
                android:clickable="true"
                android:focusable="true">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="14dp">
                    <TextView android:id="@+id/txt2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Metro" android:textColor="#0F172A" android:textStyle="bold" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/txt2" android:text="Travel" android:textColor="#64748B" android:textSize="12sp" android:layout_marginTop="2dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="₹60" android:textColor="#0F172A" android:textStyle="bold" android:textSize="14sp"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/itemQuickStationery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp"
                android:backgroundTint="#FFFFFF"
                android:clickable="true"
                android:focusable="true">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="14dp">
                    <TextView android:id="@+id/txt3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stationery Shop" android:textColor="#0F172A" android:textStyle="bold" android:textSize="14sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_below="@id/txt3" android:text="Shopping" android:textColor="#64748B" android:textSize="12sp" android:layout_marginTop="2dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="₹200" android:textColor="#0F172A" android:textStyle="bold" android:textSize="14sp"/>
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>