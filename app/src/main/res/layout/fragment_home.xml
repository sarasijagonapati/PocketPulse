<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER WELCOME BLOCK -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spendly"
                    android:textColor="#64748B"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WELCOME!"
                    android:textColor="#0F172A"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHomeMonthPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@android:drawable/editbox_dropdown_light_frame"
                android:backgroundTint="#EFF6FF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="Loading..."
                android:textColor="#2563EB"
                android:textStyle="bold"
                android:textSize="12sp" />
        </RelativeLayout>

        <!-- MAIN DYNAMIC BUDGET ACCOUNTING CARD -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mainBudgetCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:backgroundTint="#2563EB"
            android:layout_marginBottom="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvBudgetLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳 Monthly Budget"
                    android:textColor="#93C5FD"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvHomeBudgetAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvBudgetLabel"
                    android:layout_marginTop="12dp"
                    android:text="₹5,000"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentEnd="true"
                    android:layout_below="@id/tvBudgetLabel"
                    android:layout_marginTop="14dp"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvHomeSpentAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Spent ₹0"
                        android:textColor="#E0F2FE"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvHomeLeftAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Left ₹5,000"
                        android:textColor="#93C5FD"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/budgetProgressBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvHomeBudgetAmount"
                    android:layout_marginTop="16dp"
                    app:trackColor="#1E40AF"
                    app:indicatorColor="#60A5FA"
                    app:trackCornerRadius="6dp"
                    app:trackThickness="8dp"
                    android:progress="0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_below="@id/budgetProgressBar"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:id="@+id/tvHomeUsedPercentage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0% used"
                        android:textColor="#E2E8F0"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHomePredictionWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="🌱 Healthy spending rate"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:ellipsize="end"
                        android:maxLines="2" />
                </LinearLayout>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CASH EXPENSES CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvHomeCashIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:backgroundTint="#FEF3C7">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="💵"
                        android:textSize="14sp"/>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/cvHomeCashIcon"
                    android:layout_marginStart="10dp"
                    android:layout_centerVertical="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cash Expenses"
                        android:textColor="#0F172A"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total hand-entered transactions"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvHomeTotalCashSpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="₹ 0.00"
                    android:textColor="#D97706"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 🟢 NEW ADDITION: YESTERDAY'S EXPENSE COMPONENT (PERFECTLY BALANCED) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cvHomeYesterdayIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp"
                    android:backgroundTint="#EFF6FF">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="⏳"
                        android:textSize="14sp"/>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/cvHomeYesterdayIcon"
                    android:layout_marginStart="10dp"
                    android:layout_centerVertical="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yesterday's Spend"
                        android:textColor="#0F172A"
                        android:textStyle="bold"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total automated outlays yesterday"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvHomeYesterdaySpent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="₹ 0.00"
                    android:textColor="#2563EB"
                    android:textStyle="bold"
                    android:textSize="16sp"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- HORIZONTAL METRIC CARDS ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="16dp">

            <!-- Daily Limit Component -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="#FFEDD5"
                app:strokeWidth="1dp"
                android:backgroundTint="#FFFBEB">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅 Daily limit"
                        android:textColor="#D97706"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHomeDailyLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textColor="#0F172A"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:id="@+id/tvHomeDaysLeftSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="15 days left"
                        android:textColor="#A16207"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Top Spend Component -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="16dp"
                app:strokeColor="#FEF3C7"
                app:strokeWidth="1dp"
                android:backgroundTint="#FFFDF2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Top spend"
                        android:textColor="#B45309"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHomeTopSpend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#0F172A"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="14dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ANALYTICS CATEGORY PIE BREAKDOWN CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BY CATEGORY"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:weightSum="10">

                    <com.example.pocketpulse.PieChartView
                        android:id="@+id/homePieChart"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="4"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="6"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                            <View android:id="@+id/dotFood" android:layout_width="8dp" android:layout_height="8dp" android:background="#F97316" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotFood" android:layout_marginStart="8dp" android:text="Food" android:textColor="#475569" android:textSize="13sp"/>
                            <TextView android:id="@+id/tvFoodSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0% · ₹0" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                        </RelativeLayout>

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                            <View android:id="@+id/dotTravel" android:layout_width="8dp" android:layout_height="8dp" android:background="#3B82F6" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotTravel" android:layout_marginStart="8dp" android:text="Travel" android:textColor="#475569" android:textSize="13sp"/>
                            <TextView android:id="@+id/tvTravelSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0% · ₹0" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                        </RelativeLayout>

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                            <View android:id="@+id/dotShopping" android:layout_width="8dp" android:layout_height="8dp" android:background="#EC4899" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotShopping" android:layout_marginStart="8dp" android:text="Shopping" android:textColor="#475569" android:textSize="13sp"/>
                            <TextView android:id="@+id/tvShoppingSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0% · ₹0" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                        </RelativeLayout>

                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <View android:id="@+id/dotUtil" android:layout_width="8dp" android:layout_height="8dp" android:background="#A855F7" android:layout_centerVertical="true"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toEndOf="@id/dotUtil" android:layout_marginStart="8dp" android:text="Utilities" android:textColor="#475569" android:textSize="13sp"/>
                            <TextView android:id="@+id/tvUtilSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0% · ₹0" android:textColor="#0F172A" android:textSize="13sp" android:textStyle="bold"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- RECENT ACTIVITY SCRIPTS TIMELINE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:strokeColor="#E2E8F0"
            app:strokeWidth="1dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RECENT"
                        android:textColor="#475569"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvHomeViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="View All"
                        android:textColor="#2563EB"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"/>
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentTransactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>