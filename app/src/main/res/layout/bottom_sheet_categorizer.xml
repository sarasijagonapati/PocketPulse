<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="?attr/colorOutlineVariant"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Transaction Spotted!"
        android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Recipient Profile / Nickname:"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?attr/colorOnSurfaceVariant"/>

    <EditText
        android:id="@+id/etRecipientName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g., Girls Hostel Canteen"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"/>

    <TextView
        android:id="@+id/tvAmountText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="?attr/colorError"
        android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSuggestion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="?attr/colorPrimary"
        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
        android:textStyle="italic"
        android:visibility="gone"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/categoryChipGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:singleSelection="true">
        <com.google.android.material.chip.Chip android:id="@+id/chipFood" style="@style/Widget.Material3.Chip.Suggestion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Food"/>
        <com.google.android.material.chip.Chip android:id="@+id/chipShop" style="@style/Widget.Material3.Chip.Suggestion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Shopping"/>
        <com.google.android.material.chip.Chip android:id="@+id/chipTravel" style="@style/Widget.Material3.Chip.Suggestion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Travel"/>
        <com.google.android.material.chip.Chip android:id="@+id/chipEdu" style="@style/Widget.Material3.Chip.Suggestion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Education"/>
        <com.google.android.material.chip.Chip android:id="@+id/chipBills" style="@style/Widget.Material3.Chip.Suggestion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bills"/>
        <com.google.android.material.chip.Chip android:id="@+id/chipEnt" style="@style/Widget.Material3.Chip.Suggestion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Entertainment"/>
        <com.google.android.material.chip.Chip android:id="@+id/chipOther" style="@style/Widget.Material3.Chip.Suggestion" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Other"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- Hidden field that scales open when "Other" is tapped -->
    <EditText
        android:id="@+id/etCustomCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Type custom category name..."
        android:visibility="gone"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"/>

    <Button
        android:id="@+id/btnSaveTransaction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Log to Ledger" />
</LinearLayout>