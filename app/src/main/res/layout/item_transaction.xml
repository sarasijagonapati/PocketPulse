<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp"
    android:backgroundTint="#FFFFFF">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvIconContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            android:backgroundTint="#F8FAFC"
            app:strokeWidth="0dp"
            android:layout_centerVertical="true">
            <TextView
                android:id="@+id/tvTransactionIconEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🍟"
                android:textSize="20sp"/>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/llDetails"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toEndOf="@id/cvIconContainer"
            android:layout_marginStart="14dp"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/tvTransactionMerchant"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MERCHANT"
                android:textColor="#0F172A"
                android:textStyle="bold"
                android:textSize="15sp"/>

            <LinearLayout
                android:id="@+id/llBadgesRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTransactionCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textColor="#F97316"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:background="@android:drawable/editbox_dropdown_light_frame"
                    android:backgroundTint="#FFEDD5"/>

                <TextView
                    android:id="@+id/tvTransactionSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📱 SMS"
                    android:textColor="#475569"
                    android:textSize="11sp"
                    android:layout_marginStart="6dp"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:background="@android:drawable/editbox_dropdown_light_frame"
                    android:backgroundTint="#F1F5F9"/>

                <TextView
                    android:id="@+id/tvTransactionDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="• 17 Jun"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:layout_gravity="center_vertical"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvTransactionNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Optional note details here..."
                android:textColor="#64748B"
                android:textSize="12sp"
                android:textStyle="italic"
                android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="end">

            <TextView
                android:id="@+id/tvTransactionAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-₹0"
                android:textColor="#EF4444"
                android:textStyle="bold"
                android:textSize="15sp"/>

            <LinearLayout
                android:id="@+id/llActionsMenu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivTransactionEdit"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:contentDescription="Edit"
                    android:layout_marginEnd="12dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"/>

                <ImageView
                    android:id="@+id/ivTransactionDelete"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_delete"
                    android:contentDescription="Delete"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>