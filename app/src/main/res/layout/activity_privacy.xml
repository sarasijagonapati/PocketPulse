<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp">

    <!-- Screen Sub-header -->
    <TextView
        android:id="@+id/tv_header_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒 SECURITY VERIFICATION"
        android:textColor="#555555"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp" />

    <!-- 🔄 THE 3D FLIP CONTAINER -->
    <FrameLayout
        android:id="@+id/card_container"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:layout_centerInParent="true"
        android:clickable="true"
        android:focusable="true">

        <!-- 📱 FRONT CARD VIEW (Sarasija Care Message) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_front"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️"
                    android:textSize="64sp"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SARASIJA made this app with care, so dont worry about your privacy and security!"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="( Tap card to flip over )"
                    android:textColor="#4CAF50"
                    android:textSize="13sp"
                    android:layout_marginTop="32dp"
                    android:textStyle="italic" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 📱 BACK CARD VIEW (The Joke / Reassurance Message) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_back"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="28dp"
            app:cardBackgroundColor="#252A25"
            app:cardElevation="10dp"
            android:visibility="invisible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤫"
                    android:textSize="64sp"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your financial logs never leave this device. No hidden trackers, no remote web servers, just pure local Room database rows!\n\nYour numbers are safer here than secrets with your best friend. 😉"
                    android:textColor="#E0E0E0"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="( Tap to return )"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginTop="28dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <!-- Exit Button -->
    <Button
        android:id="@+id/btn_back_privacy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:text="Understood, Boss"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:paddingHorizontal="36dp"
        android:paddingVertical="12dp"
        android:textStyle="bold" />

</RelativeLayout>